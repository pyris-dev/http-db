# Universal command helper for cross-platform compatibility
get_cmd() {
    local cmd="$1"
    case "$(uname)" in
    *CYGWIN* | *MINGW* | *MSYS*)
    echo "${cmd}.cmd"
    ;;
    *)
    echo "$cmd"
    ;;
    esac
}

# Check if staged files include TypeScript files
if git diff --cached --name-only | grep -E '\.ts$' > /dev/null; then
    echo "🔍 Running TypeScript type check..."
    $(get_cmd npm) run build

    echo "🔍 Running Lint check..."
    $(get_cmd npm) run lint
else
     echo "🔍 No staged TypeScript files detected. Skipping type check and lint."
     exit 0
fi
