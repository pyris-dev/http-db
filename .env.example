# Example environment configuration 

DEBUG_MODE = true

# ----------------------------
#   Authentication Settings 
# ----------------------------

# Enable or disable authentication
AUTH_ENABLED = true
AUTH_KEY = "yoursupersecretkey"

# ----------------------------
#       Http Settings
# ----------------------------

# Application host and port
APP_HOST = "localhost"
APP_PORT = 3000

# Maximum request body size in bytes (e.g., 10MB)
MAX_REQUEST_BODY_SIZE = 10485760

# Connection idle timeout in seconds
IDLE_TIMEOUT = 15

# Enable TLS (true/false)
TLS_ENABLED = false
TLS_CERT_PATH = "./certs/cert.pem"
TLS_KEY_PATH = "./certs/key.pem"

# ----------------------------
#     Database Settings
# ----------------------------

# Options: "embedded", "server"
DATABASE_TYPE = "embedded"
# Options:  
#   (Embedded)  "sqlite"
#   (Server)    "mysql", "mongodb"
DATABASE_PLATFORM = "sqlite"

# Required for embedded databases
DATABASE_NAME = "database.db"

# Required for server databases
DATABASE_HOST = "localhost"
DATABASE_PORT = 5432
DATABASE_USER = "db_user"
DATABASE_PASSWORD = "db_password"
