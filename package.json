{
  "name": "http-db",
  "version": "1.0.2",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "tsc",
    "start": "bun run ./dist/index.js",
    "bundle": "bun run ./bundle.ts",
    "release": "npm run release:patch",
    "release:patch": "npm version patch -m \"v%s\" && git push origin main --follow-tags",
    "release:minor": "npm version minor -m \"v%s\" && git push origin main --follow-tags",
    "release:major": "npm version major -m \"v%s\" && git push origin main --follow-tags",
    "prepare": "husky",
    "clean": "rm -rf ./dist ./bundle",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.9.1",
    "eslint": "^9.30.1",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.38.0",
    "typescript": "^5.9.3"
  }
}
